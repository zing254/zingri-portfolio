# ════════════════════════════════════════════════════════════
# BAZENGA - Environment Variables Template
# Copy this file to .env.local and fill in your values
# ════════════════════════════════════════════════════════════

# ════════════════════════════════════════════════════════════
# SITE CONFIGURATION
# ════════════════════════════════════════════════════════════

# Your site's production URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://zingri.dev

# Site branding
NEXT_PUBLIC_SITE_NAME=BAZENGA
NEXT_PUBLIC_DEVELOPER_NAME=ZINGRI MASTER

# ════════════════════════════════════════════════════════════
# CONTACT FORM (EmailJS or similar)
# ════════════════════════════════════════════════════════════

# EmailJS Service ID (get from emailjs.com)
EMAIL_SERVICE_ID=your_service_id_here

# EmailJS Template ID
EMAIL_TEMPLATE_ID=your_template_id_here

# EmailJS Public Key
EMAIL_PUBLIC_KEY=your_public_key_here

# ════════════════════════════════════════════════════════════
# ANALYTICS (Optional)
# ════════════════════════════════════════════════════════════

# Google Analytics 4 Measurement ID (optional)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Google Analytics 4 API Secret (optional)
GA_API_SECRET=your_ga_api_secret_here

# ════════════════════════════════════════════════════════════
# SOCIAL LINKS OVERRIDE (Optional)
# These override the defaults in src/lib/config.ts
# ════════════════════════════════════════════════════════════

NEXT_PUBLIC_GITHUB_URL=https://github.com/zing254
# NEXT_PUBLIC_LINKEDIN_URL=
# NEXT_PUBLIC_TWITTER_URL=
# NEXT_PUBLIC_INSTAGRAM_URL=

# ════════════════════════════════════════════════════════════
# DATABASE (if needed for future features)
# ════════════════════════════════════════════════════════════

# PostgreSQL
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# MongoDB
# MONGODB_URI=mongodb://user:password@host:27017/dbname

# Redis
# REDIS_URL=redis://user:password@host:6379

# ════════════════════════════════════════════════════════════
# AUTHENTICATION (for future features)
# ════════════════════════════════════════════════════════════

# NextAuth.js Secret
# NEXTAUTH_SECRET=your_nextauth_secret_here
# NEXTAUTH_URL=http://localhost:3000

# OAuth Providers (optional)
# GITHUB_ID=your_github_oauth_id
# GITHUB_SECRET=your_github_oauth_secret
# GOOGLE_ID=your_google_oauth_id
# GOOGLE_SECRET=your_google_oauth_secret

# ════════════════════════════════════════════════════════════
# FILE STORAGE (for future features)
# ════════════════════════════════════════════════════════════

# AWS S3
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# AWS_REGION=eu-west-1
# AWS_BUCKET_NAME=bazenga-assets

# Cloudinary
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret

# ════════════════════════════════════════════════════════════
# API KEYS (for future integrations)
# ════════════════════════════════════════════════════════════

# OpenAI (for AI features)
# OPENAI_API_KEY=sk-your_openai_key

# Tawk.to (for live chat)
# TAWKTO_PROPERTY_ID=your_property_id
# TAWKTO_WIDGET_ID=your_widget_id

# ════════════════════════════════════════════════════════════
# DEVELOPMENT SETTINGS
# ════════════════════════════════════════════════════════════

# Enable debug mode (development only)
# NEXT_PUBLIC_DEBUG=true

# Log level (debug, info, warn, error)
# LOG_LEVEL=debug
